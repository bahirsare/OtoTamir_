@model OtoTamir.CORE.Utilities.PagedResult<OtoTamir.CORE.Identity.Mechanic>
@{
    ViewData["Title"] = "Silinmiş Ustalar (Çöp Kutusu)";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid pt-4">
    <div class="card card-danger card-outline shadow-sm">
        <div class="card-header">
            <h3 class="card-title text-danger fw-bold">
                <i class="bi bi-trash3-fill me-2"></i> Silinen Usta Hesapları
            </h3>
            <div class="card-tools">
                <a asp-action="Index" class="btn btn-sm btn-secondary">
                    <i class="bi bi-arrow-left"></i> Admin Panele Dön
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Ad Soyad</th>
                            <th>Kullanıcı Adı</th>
                            <th>Email</th>
                            <th>Telefon</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Results != null && Model.Results.Any())
                        {
                            foreach (var mechanic in Model.Results)
                            {
                                <tr>
                                    <td class="align-middle"><del class="text-muted">@mechanic.StoreName</del></td>
                                    <td class="align-middle">@mechanic.UserName</td>
                                    <td class="align-middle">@mechanic.Email</td>
                                    <td class="align-middle">@mechanic.PhoneNumber</td>
                                    <td class="text-end">
                                        <form asp-controller="Admin" asp-action="RestoreMechanic" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@mechanic.Id" />
                                            <button type="submit" class="btn btn-sm btn-success shadow-sm">
                                                <i class="bi bi-arrow-counterclockwise"></i> Geri Yükle
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-emoji-smile fs-3 d-block mb-2"></i>
                                    Silinmiş herhangi bir usta kaydı bulunmuyor.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.PageCount > 1)
        {
            <div class="card-footer clearfix">
                <ul class="pagination pagination-sm m-0 float-end">

                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("RecycleBin", new { page = Model.CurrentPage - 1 })">«</a>
                    </li>

                    @for (int i = 1; i <= Model.PageCount; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("RecycleBin", new { page = i })">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.PageCount ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("RecycleBin", new { page = Model.CurrentPage + 1 })">»</a>
                    </li>

                </ul>
            </div>
        }
    </div>
</div>