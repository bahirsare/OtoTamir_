@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/Shared/_LayoutAccount.cshtml";
}

<body class="login-page bg-light">
    <div class="container-fluid vh-100 d-flex align-items-center justify-content-center">
        <div class="row w-100 align-items-center">

            <div class="col-lg-6 d-none d-lg-flex justify-content-center align-items-center p-5">
                <div class="logo-wrapper text-center">
                    <img src="~/images/logo.png"
                         alt="OtoTamir Logo"
                         class="img-fluid floating-logo"
                         style="max-height: 70vh; width: auto; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));" />
                </div>
            </div>

            <div class="col-lg-5 col-md-8 mx-auto">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="d-lg-none text-center pt-4">
                        <img src="~/assets/img/logo.png" style="height: 80px;" alt="Logo" />
                    </div>

                    <div class="card-body p-5">
                        <h2 class="fw-bold mb-1 text-dark">Hoş Geldiniz</h2>
                        <p class="text-muted mb-4">Lütfen bilgilerinizi giriniz.</p>
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <strong>Hata:</strong> @TempData["ErrorMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                            </div>
                        }

                        @if (TempData["Message"] != null)
                        {
                            <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                <strong>Uyarı:</strong> @TempData["Message"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                            </div>
                        }
                        <form asp-action="Login" method="post">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Kullanıcı Adı</label>
                                <input asp-for="UserName" class="form-control form-control-lg bg-light border-0" placeholder="Kullanıcı adınız" required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted">Şifre</label>
                                <input asp-for="Password" type="password" class="form-control form-control-lg bg-light border-0" placeholder="••••••••" required />
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm fw-bold mb-3">
                                Giriş Yap
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <button class="btn btn-link btn-sm text-muted text-decoration-none" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal">
                                Şifremi Unuttum
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    @await Html.PartialAsync("_ForgotPasswordPartial")
</body>

<style>
    /* Sayfayı tam boy yap */
    .login-page {
        background: #fdfdfd !important;
        overflow-x: hidden;
    }

    /* Logonun hafifçe yüzme efekti (Premium hissettirir) */
    .floating-logo {
        animation: float 6s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    /* Input focus efektleri */
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.1);
        border: 1px solid #0d6efd !important;
    }
</style>