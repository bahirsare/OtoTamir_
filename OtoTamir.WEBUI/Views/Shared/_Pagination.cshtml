@using OtoTamir.CORE.Utilities
@using Microsoft.AspNetCore.Routing
@model PagedResultMeta

@{
    if (Model == null || Model.PageCount <= 1) { return; }

    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    
    var routeValues = new RouteValueDictionary();

    foreach (var key in ViewContext.RouteData.Values.Keys)
        routeValues[key] = ViewContext.RouteData.Values[key];

    foreach (var key in Context.Request.Query.Keys)
    {
        if (!key.Equals("page", StringComparison.OrdinalIgnoreCase) &&
            !key.Equals("id", StringComparison.OrdinalIgnoreCase))
        {
            routeValues[key] = Context.Request.Query[key];
        }
    }

    
    int rangeStart = Math.Max(1, Model.CurrentPage - 2);
    int rangeEnd = Math.Min(Model.PageCount, Model.CurrentPage + 2);
}

<div class="card-footer d-flex align-items-center justify-content-between flex-wrap gap-2">

    <div class="text-muted small">
        Toplam <strong>@Model.RowCount</strong> kayıt &mdash; Sayfa <strong>@Model.CurrentPage</strong> / <strong>@Model.PageCount</strong>
    </div>

    <nav aria-label="Sayfalama" class="ajax-pagination">
        <ul class="pagination pagination-sm m-0 shadow-sm">

            @if (Model.CurrentPage > 3)
            {
                routeValues["page"] = 1;
                <li class="page-item">
                    <a class="page-link" href="@Url.Action(currentAction, currentController, routeValues)" aria-label="İlk sayfa">
                        «« 1
                    </a>
                </li>
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

           
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                @{
                    routeValues["page"] = Model.CurrentPage - 1;
                }
                <a class="page-link" href="@Url.Action(currentAction, currentController, routeValues)" aria-label="Önceki">«</a>
            </li>

           
            @for (int i = rangeStart; i <= rangeEnd; i++)
            {
                routeValues["page"] = i;
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action(currentAction, currentController, routeValues)">@i</a>
                </li>
            }

          
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                @{
                    routeValues["page"] = Model.CurrentPage + 1;
                }
                <a class="page-link" href="@Url.Action(currentAction, currentController, routeValues)" aria-label="Sonraki">»</a>
            </li>

            
            @if (Model.CurrentPage < Model.PageCount - 2)
            {
                routeValues["page"] = Model.PageCount;
                <li class="page-item disabled"><span class="page-link">…</span></li>
                <li class="page-item">
                    <a class="page-link" href="@Url.Action(currentAction, currentController, routeValues)" aria-label="Son sayfa">
                        @Model.PageCount »»
                    </a>
                </li>
            }

        </ul>
    </nav>
   
</div>
