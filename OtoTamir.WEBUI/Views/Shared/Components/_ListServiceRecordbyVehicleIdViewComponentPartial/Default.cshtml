
@model Vehicle

@{
    var meta = ViewData["PagedResult"] as OtoTamir.CORE.Utilities.PagedResultMeta;
    var vehicleId = (int)(ViewData["VehicleId"] ?? Model?.Id ?? 0);
}

<div id="service-history-@vehicleId">

    @if (Model?.ServiceRecords != null && Model.ServiceRecords.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Başlık</th>
                        <th>Açıklama</th>
                        <th>Fiyat</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model.ServiceRecords)
                    {
                        <tr>
                            <td>@record.CreatedDate.ToString("dd.MM.yyyy")</td>
                            <td>@record.Name</td>
                            <td class="text-truncate" style="max-width:160px">@record.Description</td>
                            <td>@record.Price.ToString("C")</td>
                            <td>
                                <span class="badge @record.Status.ToBadgeClass()">
                                    @record.Status.ToTurkish()
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-info btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#detailModal-@record.Id">
                                    Detay
                                </button>

                                <div class="modal fade" id="detailModal-@record.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content">
                                            @await Component.InvokeAsync("_ListServiceRecordDetailsViewComponentPartial", record.Id)
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        
        @if (meta != null && meta.PageCount > 1)
        {
            <div class="d-flex align-items-center justify-content-between px-2 py-2 border-top">
                <small class="text-muted">
                    @meta.RowCount kayıt · Sayfa @meta.CurrentPage / @meta.PageCount
                </small>
                <nav>
                    <ul class="pagination pagination-sm m-0">

                        <li class="page-item @(!meta.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link history-page-link"
                               data-vehicle-id="@vehicleId"
                               data-page="@(meta.CurrentPage - 1)"
                               href="#">«</a>
                        </li>

                        @for (int i = Math.Max(1, meta.CurrentPage - 2);
                                        i <= Math.Min(meta.PageCount, meta.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == meta.CurrentPage ? "active" : "")">
                                <a class="page-link history-page-link"
                                   data-vehicle-id="@vehicleId"
                                   data-page="@i"
                                   href="#">@i</a>
                            </li>
                        }

                        <li class="page-item @(!meta.HasNextPage ? "disabled" : "")">
                            <a class="page-link history-page-link"
                               data-vehicle-id="@vehicleId"
                               data-page="@(meta.CurrentPage + 1)"
                               href="#">»</a>
                        </li>

                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div class="text-center text-muted py-3">
            <i class="bi bi-info-circle me-1"></i> Bu araç için servis kaydı bulunmuyor.
        </div>
    }

</div>

<script>
    (function () {
        if (window._historyPaginationBound) return;
        window._historyPaginationBound = true;

        document.addEventListener('click', function (e) {
            var link = e.target.closest('.history-page-link');
            if (!link) return;
            e.preventDefault();

            var vehicleId = link.dataset.vehicleId;
            var page      = link.dataset.page;
            var container = document.getElementById('service-history-' + vehicleId);
            if (!container) return;

            // Loading göster
            container.style.opacity = '0.5';

            fetch('/ServiceRecord/GetServiceHistory?vehicleId=' + vehicleId + '&page=' + page)
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    container.outerHTML = html;
                    container.style.opacity = '1';
                })
                .catch(function () {
                    container.style.opacity = '1';
                });
        });
    })();
</script>
