@model TreasuryDashboardDTO

<div id="transactionTableContainer">
    <div class="card-body table-responsive p-0">
        @if (Model.Transactions == null || Model.Transactions.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-search" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Kayıt Bulunamadı</h5>
            </div>
        }
        else
        {
            <table class="table table-striped table-hover table-valign-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Açıklama</th>
                        <th>Yapan</th>
                        <th>Kategori</th>
                        <th>Kaynak</th>
                        <th class="text-right">Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Transactions)
                    {
                        <tr>
                            <td class="text-nowrap"><i class="bi bi-calendar3 text-muted me-1"></i> @item.TransactionDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="fw-bold text-dark">@item.Description</span></td>
                            <td><span class="badge bg-light text-dark border">@item.AuthorName</span></td>
                            <td>
                                @if (item.TransactionCategory != null) { <span class="badge bg-info text-dark">@item.TransactionCategory.Name</span> }
                                else { <span class="text-muted small">-</span> }
                            </td>
                            <td>
                                @switch (item.PaymentSource)
                                {
                                    case OtoTamir.CORE.Entities.PaymentSource.Cash:
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success">
                                            <i class="bi bi-cash-stack me-1"></i> Nakit Kasa
                                        </span>
                                        break;

                                    case OtoTamir.CORE.Entities.PaymentSource.Bank:
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">
                                            <i class="bi bi-bank me-1"></i>
                                            @(item.Bank != null ? item.Bank.BankName +" (Banka)": "Banka Transferi")
                                        </span>
                                        break;

                                    case OtoTamir.CORE.Entities.PaymentSource.CreditCard:
                                        <span class="badge bg-warning bg-opacity-10 text-dark border border-warning">
                                            <i class="bi bi-credit-card me-1"></i>
                                            @(item.BankCard != null ? item.BankCard.CardName +" (Kart)": "Kredi Kartı")
                                        </span>
                                        break;

                                    case OtoTamir.CORE.Entities.PaymentSource.ClientBalance:
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary">
                                            <i class="bi bi-person-lines-fill me-1"></i> Cari Hesap
                                        </span>
                                        break;

                                    default:
                                        <span class="badge bg-light text-dark border">
                                            <i class="bi bi-question-circle me-1"></i> Diğer
                                        </span>
                                        break;
                                }
                            </td>
                            <td class="text-right font-weight-bold @(item.TransactionType == OtoTamir.CORE.Entities.TransactionType.Incoming ? "text-success" : "text-danger")">
                                <i class="bi @(item.TransactionType == OtoTamir.CORE.Entities.TransactionType.Incoming ? "bi-arrow-up" : "bi-arrow-down") small me-1"></i>
                                @Math.Abs(item.Amount).ToString("C2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    <div class="card-footer bg-white ajax-pagination">
        <partial name="_Pagination" model="ViewBag.PagedResult" />
    </div>
</div>